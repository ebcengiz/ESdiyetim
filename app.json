{
  "expo": {
    "name": "ESdiyet",
    "slug": "esdiyet",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.esdiyet.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Bu uygulama profil fotoğrafı eklemek için kameraya ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "Bu uygulama profil fotoğrafı seçmek için galeriye ihtiyaç duyar."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.esdiyet.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "BURAYA_EAS_PROJECT_ID_GELECEK"
      }
    }
  }
}
