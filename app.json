{
  "expo": {
    "name": "ESdiyet",
    "slug": "esdiyet",
    "version": "1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Kalori tahmini için galeriden yemek fotoğrafı seçmeniz gerekir.",
          "cameraPermission": "Kalori tahmini için yemek fotoğrafı çekebilmeniz gerekir."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.esdiyet.app",
      "buildNumber": "11",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil ve kalori tahmini için kamera kullanılır.",
        "NSPhotoLibraryUsageDescription": "Profil ve kalori tahmini için galeriden fotoğraf seçilir."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.esdiyet.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2fad153f-cc7c-45d6-9c70-5278b639de19"
      }
    }
  }
}
